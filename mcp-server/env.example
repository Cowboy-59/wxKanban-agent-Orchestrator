# MCP Project Hub Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONNECTION (Choose ONE option)
# ============================================

# Option 1: Plain DATABASE_URL (for development only)
# DATABASE_URL=postgresql://user:password@localhost:5432/wxkanban

# Option 2: Encrypted DATABASE_URL (recommended for production)
# The DATABASE_URL is encrypted using AES-256-GCM with your WXKANBAN_API_TOKEN
# Format: iv_hex:authTag_hex:ciphertext_hex
# Generate this using the KitEncryptionService or wxKanban API
DATABASE_URL_ENCRYPTED=your_encrypted_database_url_here

# Required when using DATABASE_URL_ENCRYPTED
# This is your personal API token from wxKanban Settings -> API Tokens
WXKANBAN_API_TOKEN=wxk_live_your_api_token_here

# ============================================
# API AUTHENTICATION
# ============================================

# API key for MCP server authentication
# This should match the API_KEY used by wxKanban server
API_KEY=your_api_key_here

# ============================================
# SERVER CONFIGURATION
# ============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Transport mode: stdio (for VS Code/Claude Desktop) or http (for remote)
TRANSPORT=stdio

# HTTP port (only used when TRANSPORT=http)
HTTP_PORT=3000

# ============================================
# NOTES
# ============================================

# For encrypted mode (DATABASE_URL_ENCRYPTED):
# 1. Get your API token from wxKanban Settings -> API Tokens
# 2. The server will decrypt DATABASE_URL_ENCRYPTED using WXKANBAN_API_TOKEN
# 3. The decrypted URL is held in memory only - never written to disk
# 4. If WXKANBAN_API_TOKEN is invalid, decryption will fail

# For development (plain DATABASE_URL):
# 1. Set DATABASE_URL directly
# 2. Leave DATABASE_URL_ENCRYPTED and WXKANBAN_API_TOKEN empty
# 3. Plain text mode is less secure - use only for local development

# Security:
# - Never commit .env file to git (it's in .gitignore)
# - Rotate API tokens regularly
# - Use encrypted mode for all production deployments
