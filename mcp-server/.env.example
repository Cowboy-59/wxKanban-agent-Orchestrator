# Database connection
DATABASE_URL=postgresql://username:password@localhost:5432/wxkanban

# API key for MCP server authentication
API_KEY=your-secure-api-key-here

# Transport mode: stdio (default) or http
TRANSPORT=stdio

# HTTP port (only used if TRANSPORT=http)
HTTP_PORT=3000

# Log level: debug, info, warn, error
LOG_LEVEL=info
